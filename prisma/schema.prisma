generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String       @id @default(cuid())
  phone         String       @unique
  password      String
  name          String?
  agreeOffers   Boolean      @default(false)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  clothingItems ClothingItem[]
  outfits       Outfit[]
  sessions      Session[]
  events        Event[]
  coupons       Coupon[]
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ClothingItem {
  id         String   @id @default(cuid())
  userId     String
  category   String   // TOP, BOTTOM, FULL_SUIT, SHOES, ACCESSORY
  subType    String?  // e.g., shirt, blouse, jeans, skirt, saree, dress, sneakers, heels, watch, necklace
  imagePath  String
  color      String?
  size       String?
  tags       String   @default("[]") // JSON array of tags like ["white","XL","short sleeves","V neck"]
  isFavorite Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Outfit {
  id        String       @id @default(cuid())
  userId    String
  name      String?      // e.g., "Office Meeting", "Friday Casual"
  eventNote String?      // e.g., "Client presentation"
  date      DateTime     // The day this outfit is planned/worn
  items     OutfitItem[]
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
}

model OutfitItem {
  id          String       @id @default(cuid())
  outfitId    String
  topId       String?      // ClothingItem id of category TOP
  bottomId    String?      // ClothingItem id of category BOTTOM
  fullSuitId  String?      // ClothingItem id of category FULL_SUIT (saree, dress, etc.)
  shoeId      String?      // ClothingItem id of category SHOES
  accessoryId String?      // ClothingItem id of category ACCESSORY
  outfit      Outfit       @relation(fields: [outfitId], references: [id], onDelete: Cascade)
}

model Event {
  id        String   @id @default(cuid())
  userId    String
  title     String
  date      DateTime
  time      String?
  location  String?
  eventType String
  tags      String   @default("[]")
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Store {
  id           String            @id @default(cuid())
  name         String
  phone        String            @unique
  password     String
  ownerName    String?
  city         String
  address      String?
  category     String            @default("fashion")
  logoUrl      String?
  website      String?
  isVerified   Boolean           @default(false)
  isActive     Boolean           @default(true)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  offers       StoreOffer[]
  subscription StoreSubscription?
}

model StoreOffer {
  id              String    @id @default(cuid())
  storeId         String
  title           String
  description     String?
  imageUrl        String?
  category        String
  tags            String    @default("[]")
  discountPct     Int       @default(10)
  couponCode      String?
  originalPrice   Float?
  discountedPrice Float?
  validFrom       DateTime
  validUntil      DateTime
  city            String?
  isActive        Boolean   @default(true)
  maxCoupons      Int       @default(100)
  couponsClaimed  Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  store           Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  coupons         Coupon[]
}

model Coupon {
  id           String     @id @default(cuid())
  userId       String
  storeOfferId String
  code         String     @unique
  qrData       String
  status       String     @default("active")
  claimedAt    DateTime   @default(now())
  usedAt       DateTime?
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  storeOffer   StoreOffer @relation(fields: [storeOfferId], references: [id], onDelete: Cascade)
}

model StoreSubscription {
  id           String    @id @default(cuid())
  storeId      String    @unique
  plan         String    @default("free")
  monthlyFee   Float     @default(0)
  perCouponFee Float     @default(50)
  startDate    DateTime  @default(now())
  endDate      DateTime?
  isActive     Boolean   @default(true)
  store        Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
}
